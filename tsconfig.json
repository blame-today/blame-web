{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": [],
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "$lib/*": ["./src/lib/*"],
      "$components/*": ["./src/components/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"]
}

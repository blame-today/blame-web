#!/usr/bin/env bash
# Reject commits whose message doesn't reference an issue (#NNN).
# Every commit on this repo should trace to an issue for context.
# Same pattern as the blame app repo.
#
# Activate once per clone:  scripts/setup-hooks.sh
# Bypass (emergencies only): git commit --no-verify

set -e

msg_file="$1"
content=$(grep -vE '^#' "$msg_file" || true)

first_line=$(echo "$content" | head -n 1)
if echo "$first_line" | grep -qE '^(Merge|Revert) '; then
  exit 0
fi

if echo "$content" | grep -qE '#[0-9]+'; then
  exit 0
fi

cat >&2 <<EOF
ERROR: commit message must reference an issue (e.g. #42, closes #42, (#42)).
every commit traces to an issue. file or find one, then amend the message:
  gh issue create --repo blame-today/blame-today.github.io
  gh issue list   --repo blame-today/blame-today.github.io

emergency bypass: git commit --no-verify
EOF
exit 1

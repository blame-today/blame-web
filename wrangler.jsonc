{
  "name": "blame-today",
  "main": "worker/index.js",
  "compatibility_date": "2026-06-15",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "routes": [
    { "pattern": "blame.today", "custom_domain": true }
    // www is NOT a worker custom domain — it's a proxied CNAME (TF-managed) that the
    // www->apex redirect rule 301s at the edge before the worker. removed 2026-06-16.
  ],
  "observability": {
    "enabled": true
  }
}
